# Reference only — the variable names the publisher reads. You do NOT need a .env file.
#
# For the automated (GitHub Actions) path: put these in repo Settings -> Secrets/Variables.
# For a local dry-run: set them in your shell (see SETUP-GUIDE Step 7), e.g.
#   $env:IMAGE_BASE_URL="https://raw.githubusercontent.com/you/themoneyflinch/main/content"
#
# NEVER create a real .env with your token inside this folder — GitHub web upload ignores
# .gitignore and would publish it. The token belongs only in GitHub Secrets.

IG_USER_ID=            # Instagram account ID from "Add account" (numeric).
IG_ACCESS_TOKEN=       # Instagram user access token (long-lived, ~60 days; refreshable).
IMAGE_BASE_URL=        # Public URL serving content/, no trailing slash.
LAUNCH_DATE=2026-07-20 # Day 1 of the calendar. --today publishes launch_date + N.
GRAPH_VERSION=v23.0    # Optional; bump when Meta deprecates.
# IG_GRAPH_BASE=https://graph.instagram.com   # default; the Instagram-login API host.
